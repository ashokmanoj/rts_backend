// =============================================================================
// prisma/schema.prisma — RTS (Request Tracking System)
// =============================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  Requestor
  RM
  HOD
  DeptHOD
  Management
  Admin
  HR
  FoodCommittee
}

enum MessageType {
  message
  file
  voice
  mixed
  approval
  system
}

model User {
  id           String   @id @default(uuid())
  empId        String   @unique @map("emp_id")
  name         String
  email        String   @unique
  phone        String?
  passwordHash String   @map("password_hash")
  role         Role     @default(Requestor)
  dept         String
  designation  String?
  location     String?
  isActive     Boolean  @default(true) @map("is_active")
  lastLogin    DateTime? @map("last_login")
  lastSeen     DateTime? @map("last_seen")
  createdAt    DateTime @default(now()) @map("created_at")

  rmEmpId      String?  @map("rm_emp_id")
  hodEmpId     String?  @map("hod_emp_id")

  resetPasswordToken   String?   @unique @map("reset_password_token")
  resetPasswordExpires DateTime? @map("reset_password_expires")

  rm           User?    @relation("UserRM",  fields: [rmEmpId],  references: [empId], onDelete: SetNull)
  hod          User?    @relation("UserHOD", fields: [hodEmpId], references: [empId], onDelete: SetNull)
  rmReports    User[]   @relation("UserRM")
  hodReports   User[]   @relation("UserHOD")

  requests          Request[]          @relation("RequestOwner")
  messages          ChatMessage[]      @relation("MessageSender")
  readReceipts      RequestRead[]
  loginLogs         LoginLog[]
  foodSubscription  FoodSubscription?
  foodCancellations FoodCancellation[]

  @@map("users")
}

model LoginLog {
  id        Int      @id @default(autoincrement())
  empId     String   @map("emp_id")
  loginAt   DateTime @default(now()) @map("login_at")
  logoutAt  DateTime? @map("logout_at")
  duration  Int?     @default(0) // Duration in minutes

  user      User     @relation(fields: [empId], references: [empId], onDelete: Cascade)

  @@index([empId])
  @@map("login_logs")
}

model Request {
  id             Int       @id @default(autoincrement())
  empId          String    @map("emp_id")
  purpose        String
  description    String?
  fileUrl        String?   @map("file_url")
  fileName       String?   @map("file_name")
  dept           String
  assignedDept   String    @map("assigned_dept")
  rmStatus       String    @default("--") @map("rm_status")
  rmDate         DateTime? @map("rm_date")
  hodStatus      String    @default("--") @map("hod_status")
  hodDate        DateTime? @map("hod_date")
  deptHodStatus  String    @default("--") @map("dept_hod_status")
  deptHodDate    DateTime? @map("dept_hod_date")
  forwarded      Boolean   @default(false)
  forwardedBy    String?   @map("forwarded_by")
  forwardedAt    DateTime? @map("forwarded_at")
  assignedStatus String    @default("Open") @map("assigned_status")
  isClosed       Boolean   @default(false) @map("is_closed")
  resolvedDate   DateTime? @map("resolved_date")
  resolvedBy     String?   @default("-") @map("resolved_by")
  createdAt      DateTime  @default(now()) @map("created_at")

  owner        User          @relation("RequestOwner", fields: [empId], references: [empId])
  chatMessages ChatMessage[]
  closeTicket  CloseTicket?
  readReceipts RequestRead[]

  @@index([empId])
  @@index([assignedDept])
  @@map("requests")
}

model RequestRead {
  id        Int      @id @default(autoincrement())
  requestId Int      @map("request_id")
  empId     String   @map("emp_id")
  createdAt DateTime @default(now()) @map("created_at")

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [empId], references: [empId], onDelete: Cascade)

  @@unique([requestId, empId])
  @@map("request_reads")
}

model CloseTicket {
  id          Int      @id @default(autoincrement())
  requestId   Int      @unique @map("request_id")
  description String?
  fileUrl     String?  @map("file_url")
  fileName    String?  @map("file_name")
  closedDate  DateTime @default(now()) @map("closed_date")

  request Request @relation(fields: [requestId], references: [id], onDelete: Cascade)

  @@map("close_tickets")
}

model ChatMessage {
  id           Int         @id @default(autoincrement())
  requestId    Int         @map("request_id")
  authorId     String      @map("author_id")
  author       String
  role         String
  type         MessageType @default(message)
  text         String?     @default("")
  fileUrl      String?     @map("file_url")
  fileName     String?     @map("file_name")
  isImage      Boolean     @default(false) @map("is_image")
  voiceUrl     String?     @map("voice_url")
  duration     String?
  status       String?
  purpose      String?
  changedDept  String?     @map("changed_dept")
  originalDept String?     @map("original_dept")
  createdAt    DateTime    @default(now()) @map("created_at")

  request  Request @relation(fields: [requestId], references: [id], onDelete: Cascade)
  sender   User    @relation("MessageSender", fields: [authorId], references: [empId])

  @@index([requestId])
  @@map("chat_messages")
}

model FoodSubscription {
  id            Int       @id @default(autoincrement())
  empId         String    @unique @map("emp_id")
  isActive      Boolean   @default(true) @map("is_active")
  suspendedFrom DateTime? @map("suspended_from")
  startDate     DateTime  @default(now()) @map("start_date")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [empId], references: [empId], onDelete: Cascade)

  @@map("food_subscriptions")
}

model FoodCancellation {
  id            Int      @id @default(autoincrement())
  empId         String   @map("emp_id")
  weekStartDate DateTime @map("week_start_date")
  cancelledAt   DateTime @default(now()) @map("cancelled_at")

  user User @relation(fields: [empId], references: [empId], onDelete: Cascade)

  @@unique([empId, weekStartDate])
  @@index([empId])
  @@map("food_cancellations")
}

model Holiday {
  id   Int      @id @default(autoincrement())
  date DateTime @unique
  name String

  @@map("holidays")
}
  