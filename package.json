{
  "name": "rts-backend",
  "version": "2.0.0",
  "description": "RTS — Request Tracking System backend (Prisma + Express)",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "db:push": "npx prisma db push",
    "db:seed": "node src/db/seed.js",
    "db:setup": "npx prisma generate && npx prisma db push && node src/db/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "prisma": "^5.14.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
